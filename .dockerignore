# Exclude apps/* and vendor/* but re-include A2UI build sources.
# Docker cannot re-include children of excluded parents, so use granular exclusions.
apps/*
!apps/shared
apps/shared/*
!apps/shared/OpenClawKit
apps/shared/OpenClawKit/*
!apps/shared/OpenClawKit/Sources
!apps/shared/OpenClawKit/Tools
vendor/*
!vendor/a2ui
